// CAREHIVE Prisma Schema
// PostgreSQL database models for chronic care assistant

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  age       Int
  condition String // diabetes, hypertension, etc.
  createdAt DateTime @default(now())

  healthLogs    HealthLog[]
  interventions Intervention[]
}

model HealthLog {
  id              String   @id @default(cuid())
  userId          String
  medicationTaken Boolean
  steps           Int      @default(0)
  mood            Int // 1-10 scale
  notes           String?
  timestamp       DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

model Intervention {
  id        String   @id @default(cuid())
  userId    String
  agentType String // care, lifestyle, emotional, clinician
  message   String
  priority  String   @default("medium") // low, medium, high, critical
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}
