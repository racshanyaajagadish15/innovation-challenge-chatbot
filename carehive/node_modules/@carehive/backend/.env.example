# Supabase: Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase: Project Settings → API → service_role key (backend only, keep secret)
SUPABASE_SERVICE_KEY=your_service_role_key

PORT=4000
FRONTEND_ORIGIN=http://localhost:3000

# Groq API key (https://console.groq.com/). Used for chat, clinician summaries, and vision check-in.
GROQ_API_KEY=gsk_your_key_here
# Optional: vision model for mood/posture from images (default: llama-4-scout-17b-16e-instruct)
# GROQ_VISION_MODEL=llama-4-scout-17b-16e-instruct

# Set to true to always use mock (no external LLM calls, fast demo)
# USE_MOCK_LLM=true
